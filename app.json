    "platform": [
        "windows",
        "darwin",
        "linux"
    ],
    "categories": [
        "graphics",
        "utility"
    ],
    "tags": [
        "image",
        "image-processing",
        "compress",
        "watermark",
        "convert",
        "screenshot"
    ]
